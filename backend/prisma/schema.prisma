generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  player
  organiser
}

enum SportType {
  Football
  Basketball
  Tennis
  Cricket
}

model User {
  id             String         @id @default(uuid())
  username       String         @unique
  email          String         @unique
  password       String
  role           Role
  tournaments    Tournament[]   @relation("OrganisedTournaments")
  registrations  Registration[]
  homeMatches    Match[]        @relation("HomeMatches")
  awayMatches    Match[]        @relation("AwayMatches")
  wonMatches     Match[]        @relation("WonMatches")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Tournament {
  id              String         @id @default(uuid())
  tournamentName  String         @unique
  sportType       SportType
  registrationFee Float
  latitude        Float
  longitude       Float
  organiserId     String
  organiser       User           @relation("OrganisedTournaments", fields: [organiserId], references: [id])
  registrations   Registration[]
  matches         Match[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model Registration {
  id           String     @id @default(uuid())
  userId       String
  tournamentId String
  user         User       @relation(fields: [userId], references: [id])
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  createdAt    DateTime   @default(now())

  @@unique([userId, tournamentId])
}

model Match {
  id             String     @id @default(uuid())
  tournamentId   String
  tournament     Tournament @relation(fields: [tournamentId], references: [id])
  homeTeamId     String
  homeTeam       User       @relation("HomeMatches", fields: [homeTeamId], references: [id])
  awayTeamId     String
  awayTeam       User       @relation("AwayMatches", fields: [awayTeamId], references: [id])
  homeTeamScore  Int?
  awayTeamScore  Int?
  winnerId       String?
  winner         User?      @relation("WonMatches", fields: [winnerId], references: [id])
  round          Int
  matchDate      DateTime?
  venue          String?
  travelDistance Float?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}
